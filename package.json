{
  "name": "tennis_leagues",
  "version": "0.1.0",
  "description": "Tennis league tracking app with Elo rankings",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test",
    "test:coverage": "vitest run --coverage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:desktop": "tauri build --bundles msi,nsis,deb,appimage",
    "tauri:build:ios": "tauri build --bundles dmg",
    "tauri:build:android": "tauri build --target aarch64-linux-android --bundles aab,apk"
  },
  "license": "MIT",
  "dependencies": {
    "@solidjs/router": "^0.16.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "firebase": "^11.0.0",
    "solid-js": "^1.9.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@solidjs/testing-library": "^0.8.10",
    "@tauri-apps/cli": "^2",
    "jsdom": "^29.0.2",
    "msw": "^2.13.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}